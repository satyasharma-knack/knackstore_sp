<svg viewBox="0 0 730 630" xmlns="http://www.w3.org/2000/svg" role="img" font-family="Inter, system-ui, sans-serif" style="">
  <title style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Hackathon Team Workflow</title>
  <desc style="fill:rgb(0, 0, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto">Step-by-step workflow every hackathon team must follow: receive transcript, extract requirements, write user stories, implement code, write test cases, demo.</desc>

  <!-- Background -->
  <rect width="720" height="620" fill="#f8f9fb" rx="12" style="fill:rgb(248, 249, 251);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- Title -->
  <text x="360" y="38" text-anchor="middle" font-size="15" font-weight="700" fill="#1a2340" style="fill:rgb(26, 35, 64);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:15px;font-weight:700;text-anchor:middle;dominant-baseline:auto">Hackathon Team Workflow</text>
  <text x="360" y="56" text-anchor="middle" font-size="11" fill="#6b7280" style="fill:rgb(107, 114, 128);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Every team follows this sequence for their assigned task</text>

  <!-- ── LANE LABELS ── -->
  <!-- Functional lane -->
  <rect x="16" y="76" width="96" height="440" rx="8" fill="#e8edf7" style="fill:rgb(232, 237, 247);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text transform="translate(64,296) rotate(-90)" text-anchor="middle" font-size="11" font-weight="600" fill="#3b5bdb" style="fill:rgb(59, 91, 219);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:middle;dominant-baseline:auto">Functional</text>

  <!-- Dev lane -->
  <rect x="120" y="76" width="96" height="440" rx="8" fill="#e8f5e9" style="fill:rgb(232, 245, 233);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text transform="translate(168,296) rotate(-90)" text-anchor="middle" font-size="11" font-weight="600" fill="#2e7d32" style="fill:rgb(46, 125, 50);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:middle;dominant-baseline:auto">Dev</text>

  <!-- QA lane -->
  <rect x="224" y="76" width="96" height="440" rx="8" fill="#fff3e0" style="fill:rgb(255, 243, 224);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text transform="translate(272,296) rotate(-90)" text-anchor="middle" font-size="11" font-weight="600" fill="#e65100" style="fill:rgb(230, 81, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:middle;dominant-baseline:auto">QA</text>

  <!-- All team lane -->
  <rect x="328" y="76" width="376" height="440" rx="8" fill="#f3f0fb" style="fill:rgb(243, 240, 251);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="516" y="96" text-anchor="middle" font-size="11" font-weight="600" fill="#6d28d9" style="fill:rgb(109, 40, 217);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:600;text-anchor:middle;dominant-baseline:auto">All Team</text>

  <!-- ══════════════════════════════════════
       STEP 1 — Receive Transcript (All)
       ══════════════════════════════════════ -->
  <!-- Arrow from title to step 1 -->
  <line x1="360" y1="62" x2="360" y2="114" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <rect x="280" y="114" width="160" height="52" rx="8" fill="#6d28d9" style="fill:rgb(109, 40, 217);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="360" y="135" text-anchor="middle" font-size="11" font-weight="700" fill="white" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:700;text-anchor:middle;dominant-baseline:auto">STEP 1</text>
  <text x="360" y="151" text-anchor="middle" font-size="11" fill="#e9d5ff" style="fill:rgb(233, 213, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Receive Task Transcript</text>

  <!-- ══════════════════════════════════════
       STEP 2 — Extract Requirements (FA)
       ══════════════════════════════════════ -->
  <line x1="64" y1="166" x2="64" y2="204" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <!-- connector from step1 to FA lane -->
  <line x1="280" y1="140" x2="64" y2="140" stroke="#9ca3af" stroke-width="1.2" stroke-dasharray="4,3" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.2px;stroke-dasharray:4px, 3px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <line x1="64" y1="140" x2="64" y2="204" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <rect x="22" y="204" width="84" height="62" rx="7" fill="#3b5bdb" style="fill:rgb(59, 91, 219);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="64" y="221" text-anchor="middle" font-size="10" font-weight="700" fill="white" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">STEP 2</text>
  <text x="64" y="236" text-anchor="middle" font-size="10" fill="#bfdbfe" style="fill:rgb(191, 219, 254);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Extract</text>
  <text x="64" y="249" text-anchor="middle" font-size="10" fill="#bfdbfe" style="fill:rgb(191, 219, 254);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Requirements</text>
  <text x="64" y="261" text-anchor="middle" font-size="9" fill="#93c5fd" style="fill:rgb(147, 197, 253);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:9px;font-weight:400;text-anchor:middle;dominant-baseline:auto">using AI</text>

  <!-- ══════════════════════════════════════
       STEP 3 — Write User Stories (FA)
       ══════════════════════════════════════ -->
  <line x1="64" y1="266" x2="64" y2="298" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <rect x="22" y="298" width="84" height="62" rx="7" fill="#3b5bdb" style="fill:rgb(59, 91, 219);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="64" y="315" text-anchor="middle" font-size="10" font-weight="700" fill="white" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">STEP 3</text>
  <text x="64" y="330" text-anchor="middle" font-size="10" fill="#bfdbfe" style="fill:rgb(191, 219, 254);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Write User</text>
  <text x="64" y="343" text-anchor="middle" font-size="10" fill="#bfdbfe" style="fill:rgb(191, 219, 254);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Stories</text>
  <text x="64" y="355" text-anchor="middle" font-size="9" fill="#93c5fd" style="fill:rgb(147, 197, 253);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:9px;font-weight:400;text-anchor:middle;dominant-baseline:auto">using AI</text>

  <!-- handoff arrow FA → Dev -->
  <line x1="106" y1="329" x2="126" y2="329" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- ══════════════════════════════════════
       STEP 4 — Generate Code (Dev)
       ══════════════════════════════════════ -->
  <rect x="126" y="298" width="84" height="62" rx="7" fill="#2e7d32" style="fill:rgb(46, 125, 50);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="168" y="315" text-anchor="middle" font-size="10" font-weight="700" fill="white" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">STEP 4</text>
  <text x="168" y="330" text-anchor="middle" font-size="10" fill="#bbf7d0" style="fill:rgb(187, 247, 208);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Generate</text>
  <text x="168" y="343" text-anchor="middle" font-size="10" fill="#bbf7d0" style="fill:rgb(187, 247, 208);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Code</text>
  <text x="168" y="355" text-anchor="middle" font-size="9" fill="#86efac" style="fill:rgb(134, 239, 172);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:9px;font-weight:400;text-anchor:middle;dominant-baseline:auto">using AI</text>

  <!-- handoff arrow FA → QA (user stories also go to QA) -->
  <line x1="106" y1="345" x2="114" y2="345" stroke="#9ca3af" stroke-width="1" stroke-dasharray="3,2" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1px;stroke-dasharray:3px, 2px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <line x1="114" y1="345" x2="114" y2="370" stroke="#9ca3af" stroke-width="1" stroke-dasharray="3,2" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1px;stroke-dasharray:3px, 2px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <line x1="114" y1="370" x2="230" y2="370" stroke="#9ca3af" stroke-width="1" stroke-dasharray="3,2" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1px;stroke-dasharray:3px, 2px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <!-- ══════════════════════════════════════
       STEP 4b — Write Test Cases (QA)
       ══════════════════════════════════════ -->
  <rect x="230" y="298" width="84" height="62" rx="7" fill="#e65100" style="fill:rgb(230, 81, 0);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="272" y="315" text-anchor="middle" font-size="10" font-weight="700" fill="white" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">STEP 4</text>
  <text x="272" y="330" text-anchor="middle" font-size="10" fill="#fed7aa" style="fill:rgb(254, 215, 170);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Write Test</text>
  <text x="272" y="343" text-anchor="middle" font-size="10" fill="#fed7aa" style="fill:rgb(254, 215, 170);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Cases</text>
  <text x="272" y="355" text-anchor="middle" font-size="9" fill="#fdba74" style="fill:rgb(253, 186, 116);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:9px;font-weight:400;text-anchor:middle;dominant-baseline:auto">using AI</text>

  <!-- ══════════════════════════════════════
       STEP 5 — Implement & Test (Dev + QA)
       ══════════════════════════════════════ -->
  <!-- arrows down from Dev and QA to step 5 -->
  <line x1="168" y1="360" x2="168" y2="406" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <line x1="272" y1="360" x2="272" y2="406" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <rect x="126" y="406" width="188" height="62" rx="7" fill="#1a5276" style="fill:rgb(26, 82, 118);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="220" y="423" text-anchor="middle" font-size="10" font-weight="700" fill="white" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:700;text-anchor:middle;dominant-baseline:auto">STEP 5</text>
  <text x="220" y="438" text-anchor="middle" font-size="10" fill="#bfdbfe" style="fill:rgb(191, 219, 254);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Implement &amp; Run Tests</text>
  <text x="220" y="451" text-anchor="middle" font-size="10" fill="#bfdbfe" style="fill:rgb(191, 219, 254);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:10px;font-weight:400;text-anchor:middle;dominant-baseline:auto">on KnackStore starter app</text>
  <text x="220" y="463" text-anchor="middle" font-size="9" fill="#93c5fd" style="fill:rgb(147, 197, 253);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:9px;font-weight:400;text-anchor:middle;dominant-baseline:auto">localhost:4200</text>

  <!-- ══════════════════════════════════════
       STEP 6 — Demo (All)
       ══════════════════════════════════════ -->
  <line x1="360" y1="468" x2="360" y2="508" stroke="#9ca3af" stroke-width="1.5" marker-end="url(#arr)" style="fill:rgb(0, 0, 0);stroke:rgb(156, 163, 175);color:rgb(0, 0, 0);stroke-width:1.5px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>

  <rect x="280" y="508" width="160" height="52" rx="8" fill="#6d28d9" style="fill:rgb(109, 40, 217);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:16px;font-weight:400;text-anchor:start;dominant-baseline:auto"/>
  <text x="360" y="527" text-anchor="middle" font-size="11" font-weight="700" fill="white" style="fill:rgb(255, 255, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:700;text-anchor:middle;dominant-baseline:auto">STEP 6</text>
  <text x="360" y="544" text-anchor="middle" font-size="11" fill="#e9d5ff" style="fill:rgb(233, 213, 255);stroke:none;color:rgb(0, 0, 0);stroke-width:1px;stroke-linecap:butt;stroke-linejoin:miter;opacity:1;font-family:Inter, system-ui, sans-serif;font-size:11px;font-weight:400;text-anchor:middle;dominant-baseline:auto">Demo &amp; Judging</text>

  <!-- ══════════════════════════════════════
       RIGHT-SIDE ANNOTATIONS
       ══════════════════════════════════════ -->
  <!-- Step 1 annotation -->
